# --- Regras para o Angular / Node.js (ui) ---
# Ignora dependências instaladas
/ui/node_modules/
/ui/dist/
/ui/out-tsc/
/ui/.angular/

# --- Regras para o ASP.NET Core (api) ---
# Ignora arquivos de compilação e execução
/api/bin/
/api/obj/
/api/.vs/
/api/.vscode/
/api/appsettings.Development.json

# --- Regras Gerais (Ambos) ---
# Arquivos de sistema
.DS_Store
Thumbs.db

# Arquivos de ambiente sensíveis (MUITO IMPORTANTE!)
# Nunca suba chaves de API, senhas de banco ou conexões reais
*.env
*.secrets
*.json.user

# Arquivos de log
*.log